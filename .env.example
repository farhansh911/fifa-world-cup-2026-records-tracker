# Supabase → Project Settings → API
# URL must be the full Project URL (https://xxxx.supabase.co), not just the project ID
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Anon key is the long JWT starting with eyJ...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: extra live data from API-Football (100 free requests/day at api-football.com)
# Scores already load automatically from ESPN — this key is optional.
API_FOOTBALL_KEY=
